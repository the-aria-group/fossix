{
  "name": "@the-aria-group/fossix",
  "version": "1.0.0",
  "description": "Aria — reliable DataStore wrapper for roblox-ts with session locking and autosave.",
  "homepage": "https://github.com/the-aria-group",
  "repository": {
    "type": "git",
    "url": "https://github.com/the-aria-group/fossix.git"
  },
  "main": "out/index.lua",
  "types": "src/index.ts",
  "scripts": {
    "build": "rbxtsc --noInclude",
    "watch": "rbxtsc --watch --noInclude",
    "typecheck": "rbxtsc --noInclude",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"*.json\" \"*.md\"",
    "test": "npm run typecheck && npm run lint"
  },
  "keywords": [
    "roblox",
    "roblox-ts",
    "datastore",
    "session-locking",
    "autosave"
  ],
  "author": "Aria <https://github.com/the-aria-group>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "commonjs",
  "files": [
    "out",
    "src",
    "README.md",
    "LICENSE",
    "wally.toml",
    "default.project.json"
  ],
  "devDependencies": {
    "@rbxts/compiler-types": "^3.0.0-types.0",
    "@rbxts/services": "^1.6.0",
    "@rbxts/testez": "^0.4.2-ts.0",
    "@rbxts/types": "^1.0.916",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@typescript-to-lua/language-extensions": "^1.19.0",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "roblox-ts": "^3.0.0",
    "typescript": "^5.9.3",
    "typescript-to-lua": "^1.34.0"
  },
  "dependencies": {
    "@rbxts/signal": "^1.1.1"
  }
}
